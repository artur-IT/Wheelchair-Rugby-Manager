---
const error = Astro.url.searchParams.get("error");
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Logowanie</title>
  </head>
  <body>
    <main style="max-width: 420px; margin: 48px auto; padding: 0 16px;">
      <h1>Logowanie</h1>

      {error && <p style="color: #b91c1c; margin-top: 12px;">Błędny PIN / hasło. Spróbuj ponownie.</p>}

      <form method="post" action="/api/login" style="margin-top: 16px;">
        <label style="display: block; margin-bottom: 8px;">
          PIN
          <input
            name="pin"
            type="password"
            autocomplete="current-password"
            required
            style="display: block; width: 100%; padding: 8px; margin-top: 6px;"
          />
        </label>

        <button type="submit" style="padding: 8px 12px;">Zaloguj</button>
      </form>
    </main>
  </body>
</html>
